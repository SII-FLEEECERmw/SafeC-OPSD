# Required: local path to the teacher model checkpoint
TEACHER_MODEL_PATH=/path/to/teacher_model

# Optional (defaults shown)
NUM_GPUS=8
TP_SIZE=1
GATEWAY_PORT=8000
START_PORT=8001
GPU_UTIL=0.60
DTYPE=bfloat16
MAX_MODEL_LEN=8192
INFERENCE_BATCH_SIZE=6
REWARD_WORKER_LOGDIR=./reward_worker_logs

# Optional: override the worker script location (defaults to the
# server_onpolicy_reward.py file shipped next to server_gateway.py)
# REWARD_WORKER_PATH=/abs/path/to/server_onpolicy_reward.py
